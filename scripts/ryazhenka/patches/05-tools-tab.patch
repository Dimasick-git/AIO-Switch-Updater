+                auto* t = dynamic_cast<brls::ToggleListItem*>(v);
+                if (!t) return;
+                if (captured.critical) {
+                    util::showDialogBoxInfo("menus/ryazhenka/sysmodule_critical"_i18n);
+                    return;
+                }
+                const bool desired = t->getToggleState();
