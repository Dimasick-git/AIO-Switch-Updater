diff --git a/source/utils.cpp b/source/utils.cpp
index 4a3ffaa..1406151 100644
--- a/source/utils.cpp
+++ b/source/utils.cpp
@@ -353,6 +353,18 @@ namespace util {
     {
         std::string res;
         switch (status_code) {
+            case 0:
+                // libcurl never received an HTTP status — DNS failure, refused
+                // connection or a timeout. The old "error: 0" was meaningless.
+                res = "menus/errors/timeout_zero"_i18n;
+                break;
+            case 404:
+                res = "menus/errors/http_not_found"_i18n;
+                break;
+            case 403:
+            case 406:
+                res = fmt::format("menus/errors/http_forbidden"_i18n, status_code);
+                break;
             case 500:
                 res = fmt::format("{0:}: Internal Server Error", status_code);
                 break;
@@ -360,7 +372,10 @@ namespace util {
                 res = fmt::format("{0:}: Service Temporarily Unavailable", status_code);
                 break;
             default:
-                res = fmt::format("error: {0:}", status_code);
+                if (status_code >= 400 && status_code < 600)
+                    res = fmt::format("menus/errors/http_generic"_i18n, status_code);
+                else
+                    res = fmt::format("error: {0:}", status_code);
                 break;
         }
         return res;
